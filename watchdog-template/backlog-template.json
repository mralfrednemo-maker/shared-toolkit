{
  "schema": "durable-watchdog-backlog-v1",
  "project_name": "Example Project",
  "project_root": "C:\\path\\to\\project",
  "goal": "Describe the final outcome that must be reached before the supervisor can stop.",
  "status": "running",
  "created_at": null,
  "updated_at": null,
  "completed_at": null,
  "notification": {
    "mode": "ActionRequired",
    "telegram_bridge": "http://127.0.0.1:9788/agora/send",
    "repeat_alert_minutes": 120
  },
  "external_monitor": {
    "enabled": false,
    "poll_seconds": 300,
    "event_log": "external-monitor-events.jsonl",
    "state_file": "external-monitor-state.json",
    "supervisor_script": "C:\\Users\\chris\\PROJECTS\\shared\\watchdog-template\\supervisor-template.ps1",
    "scheduled_task_name": "Example Project External Monitor",
    "terminal_statuses": ["complete", "blocked", "skipped"],
    "controller_heartbeat_file": "",
    "controller_heartbeat_stale_seconds": 420,
    "controller_wake_command": "",
    "wake_cooldown_seconds": 300,
    "wake_runner_file": "external-monitor-wake-runner.ps1",
    "wake_log_file": "external-monitor-wake.log",
    "wake_state_file": "external-monitor-wake-state.json"
  },
  "ralph_observer": {
    "enabled": false,
    "mode": "passive",
    "poll_seconds": 300,
    "event_log": "ralph-observer-events.jsonl",
    "state_file": "ralph-observer-state.json",
    "loop_state_file": "orchestrator-loop-state.json",
    "loop_status_path": ["status"],
    "healthy_statuses": ["ready_for_guru_loop", "running", "in_progress"],
    "action_required_statuses": ["action_required", "blocked", "blocked_pending_guru_url"],
    "final_statuses": ["final_delivery_keyword_seen", "complete"],
    "controller_heartbeat_file": "orchestrator-heartbeat.json",
    "controller_heartbeat_stale_seconds": 420,
    "authority_counter_file": "orchestration-loop-counters.json",
    "active_guru_url_required": true,
    "final_keyword": "FULL_WORKING_CODE_DELIVERED",
    "forbidden_actions": ["guru_contact", "codex_launch", "session_wake", "product_edit", "authority_write"]
  },
  "progress_updates": {
    "enabled": false,
    "interval_seconds": 900,
    "summary_command": "Write-Output 'Sentence one. Sentence two. Sentence three. RUNNING AS PLANNED'",
    "state_file": "progress-state.json",
    "external_terminal_updates": true
  },
  "supervisor": {
    "interval_seconds": 300,
    "stalled_after_minutes": 45,
    "max_retries_per_item": 3,
    "event_log": "supervisor-events.jsonl",
    "state_file": "supervisor-state.json"
  },
  "final_validation_command": "exit 0",
  "items": [
    {
      "id": "ITEM-001",
      "description": "Replace this with a real backlog item.",
      "required": true,
      "status": "pending",
      "attempts": 0,
      "run_command": "Write-Output 'start work here'",
      "check_command": "exit 1",
      "recover_command": "",
      "state_tracking": {
        "enabled": false,
        "state_file": "dialogue-state.json",
        "status_path": ["items", "ITEM-001", "status"],
        "done_statuses": ["done", "closed_accepted", "closed_accepted_with_notes"],
        "blocked_statuses": ["blocked", "blocked_needs_human", "rejected", "failed", "failed_safely"],
        "running_statuses": ["running", "in_progress"],
        "waiting_statuses": ["waiting", "pending", "queued"]
      },
      "heartbeat_tracking": {
        "enabled": false,
        "heartbeat_file": "agent-heartbeat.json",
        "stale_after_seconds": 300
      },
      "last_started_at": null,
      "last_checked_at": null,
      "last_finished_at": null,
      "last_error": null,
      "evidence": []
    }
  ]
}
